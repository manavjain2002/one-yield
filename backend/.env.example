# Server
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:8080

# Database
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=oneyield
DATABASE_PASSWORD=oneyield
DATABASE_NAME=oneyield

# Redis (BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6379

# Hedera
HEDERA_NETWORK=testnet
HEDERA_MIRROR_NODE_URL=https://testnet.mirrornode.hedera.com
# Factory on Hedera EVM (0x) or native contract id 0.0.x
FACTORY_CONTRACT_ID=0xe9BE1b4E0dB6AF4123562CB01A5B44fD66606647

# Addresses for pool creation (used by ROLE_MANAGER signature).
POOL_MANAGER_ADDRESS=0xe9BE1b4E0dB6AF4123562CB01A5B44fD66606647
ORACLE_MANAGER_ADDRESS=0xe9BE1b4E0dB6AF4123562CB01A5B44fD66606647
FEE_COLLECTOR_ADDRESS=0xe9BE1b4E0dB6AF4123562CB01A5B44fD66606647

# Default pool token when POST /pools omits poolTokenAddress (mock USDC testnet)
MOCK_USDC_EVM_ADDRESS=0x1Cf407eCB2Cd690d4E6E3F465111E019032ACA74

# Platform signers — use standard 32-byte hex EVM private keys (0x...). Production: Vault / AWS SM.
PLATFORM_ADMIN_PRIVATE_KEY=
ROLE_MANAGER_PRIVATE_KEY=
POOL_MANAGER_PRIVATE_KEY=
ORACLE_PRIVATE_KEY=
FM_ADMIN_PRIVATE_KEY=

# Optional JSON array: [{"privateKey":"0x..."}]
DEDICATED_WALLETS_JSON=

# JWT
JWT_SECRET=change-me-in-production-min-32-chars-long
JWT_EXPIRES_IN=1d
JWT_REFRESH_EXPIRES_IN=24h

# Chainalysis (optional stub if empty)
CHAINALYSIS_API_KEY=

# Oracle cron: 6 AM IST = 00:30 UTC
ORACLE_CRON=30 0 * * *

# Indexer poll seconds
INDEXER_POLL_INTERVAL_SEC=15
