# Frontend — copy to .env.local for Vite
# Backend origin (include https:// in production). If you omit the scheme, https:// is assumed.
VITE_API_URL=http://localhost:3001
# Socket.IO base (same host as API). Defaults to VITE_API_URL when unset.
VITE_WS_URL=http://localhost:3001
#
# Production (Railway) — set these in the frontend service, not in git:
# VITE_API_URL=https://one-yield-backend-production.up.railway.app
# VITE_WS_URL=https://one-yield-backend-production.up.railway.app
# Used by Wagmi + UI (`src/lib/wagmi-target-chain.ts`). Prefer this over legacy VITE_HEDERA_NETWORK.
VITE_NETWORK=testnet
VITE_MIRROR_NODE_URL=https://testnet.mirrornode.hedera.com
# Hedera EVM addresses (defaults built into `src/lib/chain-constants.ts`)
# VITE_FACTORY_CONTRACT_ADDRESS=0xe9BE1b4E0dB6AF4123562CB01A5B44fD66606647
# VITE_MOCK_USDC_ADDRESS=0x1Cf407eCB2Cd690d4E6E3F465111E019032ACA74
# VITE_HEDERA_EVM_RPC_URL=https://testnet.hashio.io/api
# VITE_MOCK_WALLET_EVM=0x0000000000000000000000000000000000000001

# Optional: WalletConnect project id for Blade QR flow (Blade ships a default if unset)
# VITE_WALLETCONNECT_PROJECT_ID=

# MetaMask / Hedera EVM chain id override (hex or decimal). Defaults: testnet 0x128, mainnet 0x127
# VITE_HEDERA_EVM_CHAIN_ID=0x128

# Use mock wallet + mock data path when backend is off (no JWT)
# VITE_USE_MOCK_WALLET=true
